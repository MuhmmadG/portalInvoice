<Window x:Class="Invoice.UI.Views.FinancialTransactionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:core="clr-namespace:Invoice.Core.Model;assembly=Invoice.Core"
        xmlns:conv="clr-namespace:Invoice.UI.Converters"
        mc:Ignorable="d"
        Title="💵 شاشة السداد والتحصيل"
        Height="780" Width="1100"
        Background="#F3F4F6"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen">

    <!-- 🎯 Resources -->
    <Window.Resources>
        <ObjectDataProvider x:Key="TransactionTypes"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="core:TransactionType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="PaymentMethods"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="core:PaymentMethod"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 🔹 العنوان -->
        <Border Background="#2563EB" CornerRadius="10" Padding="15" Margin="0 0 0 10">
            <TextBlock Text="شاشة السداد والتحصيل"
                       Foreground="White" FontSize="26"
                       FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <!-- 🧾 إدخال البيانات -->
        <Border Grid.Row="1" Background="White" CornerRadius="10"
        BorderBrush="#E5E7EB" BorderThickness="1" Padding="20" Margin="0 0 0 10">

           

                <!-- ✅ الحل: وضع كل شيء داخل StackPanel رئيسي -->
                <StackPanel>

                    <UniformGrid Columns="4" Rows="6" Margin="0 0 0 10">

                        <!-- نوع الحركة -->
                        <StackPanel Margin="5">
                            <TextBlock Text="📘 نوع الحركة" FontWeight="Bold"/>
                            <ComboBox ItemsSource="{Binding Source={StaticResource TransactionTypes}}"
                              SelectedItem="{Binding SelectedTransactionType, Mode=TwoWay}"
                              Width="200"/>
                        </StackPanel>

                        <!-- نوع المصروف -->
                        <StackPanel Margin="5"
                            Visibility="{Binding IsPaymentMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="💼 نوع المصروف" FontWeight="Bold"/>
                            <ComboBox ItemsSource="{Binding ExpenseCategories}"
                              DisplayMemberPath="CategoryType"
                              SelectedItem="{Binding SelectedExpenseCategory, Mode=TwoWay}"
                              Width="200"/>
                        </StackPanel>

                        <!-- بيان المصروف -->
                        <StackPanel Margin="5"
                            Visibility="{Binding IsPaymentMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="🧾 بيان المصروف" FontWeight="Bold"/>
                            <ComboBox ItemsSource="{Binding FilteredOtherExpenses}"
                              DisplayMemberPath="Description"
                              SelectedItem="{Binding SelectedOtherExpense, Mode=TwoWay}"
                              Width="200"/>
                        </StackPanel>

                        <!-- اسم الطرف -->
                        <StackPanel Margin="5">
                            <TextBlock Text="🏢 اسم الطرف" FontWeight="Bold"/>
                            <ComboBox ItemsSource="{Binding FilteredParties}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedParty, Mode=TwoWay}"
                              Width="200"/>
                        </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="📊 رصيد الطرف" FontWeight="Bold"/>
                        <TextBox Text="{Binding PartyBalance, StringFormat=N2}"
             IsReadOnly="True"
             Background="#F3F4F6"
             Width="180"/>
                    </StackPanel>
                    <!-- رقم الفاتورة -->
                        <StackPanel Margin="5">
                            <TextBlock Text="📄 رقم الفاتورة" FontWeight="Bold"/>
                            <ComboBox ItemsSource="{Binding FilteredDocuments}"
                              DisplayMemberPath="InternalId"
                              SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                              Width="180"/>
                        </StackPanel>

                        <!-- التاريخ -->
                        <StackPanel Margin="5">
                            <TextBlock Text="📅 التاريخ" FontWeight="Bold"/>
                            <DatePicker SelectedDate="{Binding Date, Mode=TwoWay,StringFormat={}{0:yyyy/MM/dd}}" Width="180"/>
                        </StackPanel>

                        <!-- القيمة -->
                        <StackPanel Margin="5">
                            <TextBlock Text="💰 المبلغ" FontWeight="Bold"/>
                        <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                        <TextBlock Text="{Binding ValidationMessage}" Foreground="Red" FontWeight="Bold"/>
                        </StackPanel>

                        <!-- طريقة السداد -->
                        <StackPanel Margin="5">
                            <TextBlock Text="💳 طريقة السداد" FontWeight="Bold"/>
                            <ComboBox ItemsSource="{Binding Source={StaticResource PaymentMethods}}"
                              SelectedItem="{Binding SelectedPaymentMethod, Mode=TwoWay}"
                              Width="180"/>
                        </StackPanel>

                        <!-- رقم الشيك -->
                        <StackPanel Margin="5"
                            Visibility="{Binding IsChequeFieldsVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="🔢 رقم الشيك" FontWeight="Bold"/>
                            <TextBox Text="{Binding ChequeNumber, Mode=TwoWay}" Width="180"/>
                        </StackPanel>

                        <!-- تاريخ الاستحقاق -->
                        <StackPanel Margin="5"
                            Visibility="{Binding IsChequeFieldsVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="📅 تاريخ الاستحقاق" FontWeight="Bold"/>
                            <DatePicker SelectedDate="{Binding DueDate, Mode=TwoWay}" Width="180"/>
                        </StackPanel>

                        <!-- البنك -->
                        <StackPanel Margin="5"
                            Visibility="{Binding IsBankFieldsVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="🏦 اسم البنك" FontWeight="Bold"/>
                            <TextBox Text="{Binding BankName, Mode=TwoWay}" Width="180"/>
                        </StackPanel>

                        <!-- رقم الحساب -->
                        <StackPanel Margin="5"
                            Visibility="{Binding IsBankFieldsVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="🔢 رقم الحساب البنكي" FontWeight="Bold"/>
                            <TextBox Text="{Binding BankAccountNumber, Mode=TwoWay}" Width="180"/>
                        </StackPanel>

                        <!-- 📝 ملاحظات -->
                        <StackPanel Margin="0 3 0 0">
                            <TextBlock Text="📝 ملاحظات" FontWeight="Bold"/>
                            <TextBox Text="{Binding Notes, Mode=TwoWay}"
                          TextWrapping="Wrap"
                                 Width =" 180"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </UniformGrid>

                </StackPanel>
          
        </Border>


        <!-- 📋 الجدول -->
        <Border Grid.Row="1" Background="White" CornerRadius="10"
                BorderBrush="#E5E7EB" BorderThickness="1" Padding="10" Margin="0,287,0,10" Grid.RowSpan="2">
            <DataGrid ItemsSource="{Binding Transactions}"
                      SelectedItem="{Binding SelectedTransaction, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="35"
                      AlternatingRowBackground="#F9FAFB"
                      FontSize="14" Margin="0,-94,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="📅 التاريخ" Binding="{Binding Date, StringFormat={}{0:yyyy/MM/dd}}" Width="100"/>
                    <DataGridTextColumn Header="نوع الحركة" Binding="{Binding TransactionType}" Width="120"/>
                    <DataGridTextColumn Header="الطرف" Binding="{Binding Party.Name}" Width="150"/>
                    
                    <DataGridTextColumn Header="الفاتورة" Binding="{Binding DocumentModel.InternalId}" Width="120"/>
                    <DataGridTextColumn Header="القيمة" Binding="{Binding Amount, StringFormat={}{0:N2}}" Width="120"/>
                    <DataGridTextColumn Header="الطريقة" Binding="{Binding PaymentMethod}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 🔘 الأزرار -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 5 0 0">
            <Button Content="➕ إضافة" Command="{Binding AddCommand}" Background="#22C55E" Foreground="White"
                    Padding="8 4" Width="120" FontWeight="Bold" Margin="5" Cursor="Hand"/>
            <Button Content="💾 حفظ" Command="{Binding SaveCommand}" Background="#2563EB" Foreground="White"
                    Padding="8 4" Width="120" FontWeight="Bold" Margin="5" Cursor="Hand"/>
            <Button Content="🗑 حذف" Command="{Binding DeleteCommand}" Background="#DC2626" Foreground="White"
                    Padding="8 4" Width="120" FontWeight="Bold" Margin="5" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>

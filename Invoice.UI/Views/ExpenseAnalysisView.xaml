<Window x:Class="Invoice.UI.Views.ExpenseAnalysisView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تحليل المصروفات"
        WindowStartupLocation="CenterScreen"
         WindowStyle="SingleBorderWindow"
         ResizeMode="CanResize"            
        ShowInTaskbar="True"
        AllowsTransparency="False"
        Background="#F8F9FB"
        Width="1200" Height="700">

    <Window.Resources>
        <!-- نفس استايل الأزرار في Dashboard -->
        <Style x:Key="MainButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="15 5"/>
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="BorderBrush" Value="#2196F3"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#0D47A1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2196F3"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- العنوان الرئيسي -->
        <TextBlock Text="تحليل المصروفات"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="#333"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 25"/>


        <!-- الفلاتر -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 0 0 20">

            <!-- من تاريخ -->
            <TextBlock Text="من:"
                       VerticalAlignment="Center"
                       Margin="0 0 10 0"
                       FontSize="18"/>

            <DatePicker Width="180"
                        SelectedDate="{Binding DateFrom}"
                        FontSize="18"/>

            <!-- إلى تاريخ -->
            <TextBlock Text="إلى:"
                       VerticalAlignment="Center"
                       Margin="20 0 10 0"
                       FontSize="18"/>

            <DatePicker Width="180"
                        SelectedDate="{Binding DateTo}"
                        FontSize="18"/>

            <!-- نوع المصروف -->
            <TextBlock Text="نوع المصروف:"
                       VerticalAlignment="Center"
                       Margin="30 0 10 0"
                       FontSize="18"/>

            <ComboBox Width="220"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      FontSize="18"/>

            <!-- تصدير الى Excel -->
            <Button Content="📤 تصدير Excel"
                    Command="{Binding ExportToExcelCommand}"
                    Style="{StaticResource MainButtonStyle}"
                    Margin="40 0 0 0"/>
        </StackPanel>


        <!-- جدول النتائج -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Results}"
                  AutoGenerateColumns="False"
                  FontSize="18"
                  RowHeight="38"
                  CanUserAddRows="False"
                  Margin="0 10 0 0"
                  Background="White"
                  BorderBrush="#DDD"
                  BorderThickness="1">
            <DataGrid.Columns>

                <DataGridTextColumn Header="الإجمالي" Binding="{Binding Total}" Width="120"/>
                <DataGridTextColumn Header="الضريبة" Binding="{Binding TaxAmount}" Width="120"/>
                <DataGridTextColumn Header="الصافي" Binding="{Binding NetAmount}" Width="120"/>
                <DataGridTextColumn Header="اسم المورد" Binding="{Binding SupplierName}" Width="200"/>
                <DataGridTextColumn Header="رقم داخلي" Binding="{Binding InternalId}" Width="130"/>
                <DataGridTextColumn Header="التاريخ" Binding="{Binding Date, StringFormat={}{0:yyyy/MM/dd}}" Width="150"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>

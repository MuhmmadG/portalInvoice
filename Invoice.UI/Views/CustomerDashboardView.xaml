<Window x:Class="Invoice.UI.Views.CustomerDashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        WindowStartupLocation="CenterScreen"
         ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow"
        WindowState="Normal"
        Title="Dashboard"
        Width="1400"
        Height="950"
        Background="#F2F2F7">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- KPIs -->
            <RowDefinition Height="Auto"/>
            <!-- Filters -->
            <RowDefinition Height="*"/>
            <!-- Charts -->
        </Grid.RowDefinitions>

        <!-- ================= KPI CARDS ================= -->
        <!-- ================= KPI CARDS ================= -->
        <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Margin="0 30 0 30"
            >
            <!-- كرت 1 -->
            <Border Background="White" CornerRadius="12" Padding="20"
            Width="250" Height="120" Margin="10"
            BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="إجمالي المبيعات" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{Binding TotalSalesKPI}"
                       FontSize="22" Foreground="#3B82F6" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- كرت 2 -->
            <Border Background="White" CornerRadius="12" Padding="20"
            Width="250" Height="120" Margin="10"
            BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="أعلى صنف مبيعاً" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{Binding BestItemKPI}"
                       FontSize="22" Foreground="#10B981" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- كرت 3 -->
            <Border Background="White" CornerRadius="12" Padding="20"
            Width="250" Height="120" Margin="10"
            BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="إجمالي الكميات" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{Binding TotalQuantityKPI}"
                       FontSize="22" Foreground="#EF4444" FontWeight="Bold"/>
                </StackPanel>
            </Border>

        </StackPanel>


        <!-- ================= FILTERS ================= -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="1" Margin="0 0 0 20">
            <ComboBox Width="180"
              ItemsSource="{Binding AvailableItems}"
              SelectedItem="{Binding SelectedItem}"
              IsEditable="True"
              Text="اختر الصنف"
              Margin="0,0,15,0"/>
            <ComboBox Width="180"
              ItemsSource="{Binding AvailableYears}"
              SelectedItem="{Binding SelectedYear}"
              IsEditable="True"
              Text="اختر السنة"/>
        </StackPanel>


        <!-- ================= CHARTS ================= -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <!-- PRICE TREND (Quarter) -->
                <Border Background="White" CornerRadius="12" Padding="20" Margin="0 0 0 30">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="350"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="⏳ (تطور أسعار الصنف (التحليل الربع سنوي"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0 0 0 10"/>

                        <oxy:PlotView Grid.Row="1"
                                      Model="{Binding PriceTrendModel}"/>
                    </Grid>
                </Border>

                <!-- TOP 5 ITEMS BAR CHART -->
                <Border Background="White" CornerRadius="12" Padding="20" Margin="0 0 0 30">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="350"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="📦 أعلى  أصناف من حيث الكمية"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0 0 0 10"/>

                        <oxy:PlotView Grid.Row="1"
                                      Model="{Binding TopItemsModel}"/>
                    </Grid>
                </Border>

                <!-- PIE CHART - SHARE -->
                <Border Background="White" CornerRadius="12" Padding="20" Margin="0 0 0 30">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="350"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="🍰 توزيع المبيعات حسب الأصناف"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0 0 0 10"
                                   HorizontalAlignment="Center"/>

                        <oxy:PlotView Grid.Row="1"
                                      Model="{Binding ItemsPieModel}"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</Window>

<Window x:Class="Invoice.UI.Views.CustomerDashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Dashboard"
        Width="1400"
        Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F7">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- KPI -->
            <RowDefinition Height="Auto"/>
            <!-- Filters -->
            <RowDefinition Height="*"/>
            <!-- Charts -->
        </Grid.RowDefinitions>

        <!-- ================= KPI CARDS ================= -->

        <UniformGrid Grid.Row="0"
                     Columns="3"
                     Margin="0 0 0 20">

            <!-- Total Sales -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="20"
                    Margin="10"
                    BorderBrush="#DDD"
                    BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="إجمالي المبيعات"
                               FontWeight="Bold"
                               FontSize="16"/>

                    <TextBlock Text="{Binding TotalSalesKPI}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#3B82F6"/>
                </StackPanel>
            </Border>

            <!-- Best Item -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="20"
                    Margin="10"
                    BorderBrush="#DDD"
                    BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="أعلى صنف مبيعاً"
                               FontWeight="Bold"
                               FontSize="16"/>

                    <TextBlock Text="{Binding BestItemKPI}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#10B981"/>
                </StackPanel>
            </Border>

            <!-- Total Quantity -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="20"
                    Margin="10"
                    BorderBrush="#DDD"
                    BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="إجمالي الكميات"
                               FontWeight="Bold"
                               FontSize="16"/>

                    <TextBlock Text="{Binding TotalQuantityKPI}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#EF4444"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- ================= FILTERS ================= -->

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0 0 0 20">

            <ComboBox Width="200"
                      Margin="10"
                      ItemsSource="{Binding AvailableItems}"
                      SelectedItem="{Binding SelectedItem}"
                      IsEditable="True"
                      Text="اختر الصنف"/>

            <ComboBox Width="200"
                      Margin="10"
                      ItemsSource="{Binding AvailableYears}"
                      SelectedItem="{Binding SelectedYear}"
                      IsEditable="True"
                      Text="اختر السنة"/>

        </StackPanel>


        <!-- ================= CHARTS ================= -->

        <Grid Grid.Row="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PRICE TREND -->

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Margin="10"
                    Padding="20"
                    Background="White"
                    CornerRadius="10">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="تطور الأسعار"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0 0 0 10"/>

                    <oxy:PlotView Grid.Row="1"
                                  Model="{Binding PriceTrendModel}"/>

                </Grid>

            </Border>

            <!-- QUANTITY TREND -->

            <Border Grid.Row="0"
                    Grid.Column="1"
                    Margin="10"
                    Padding="20"
                    Background="White"
                    CornerRadius="10">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="أعلى الأصناف من حيث الكمية"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0 0 0 10"/>

                    <oxy:PlotView Grid.Row="1"
                                  Model="{Binding QuantityTrendModel}"/>

                </Grid>

            </Border>

            <!-- PIE CHART -->

            <Border Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="10"
                    Padding="20"
                    Background="White"
                    CornerRadius="10">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="توزيع المبيعات حسب الأصناف"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0 0 0 10"
                               HorizontalAlignment="Center"/>

                    <oxy:PlotView Grid.Row="1"
                                  Model="{Binding ItemsPieModel}"/>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Window>
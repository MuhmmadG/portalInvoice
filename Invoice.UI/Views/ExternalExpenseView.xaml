<Window x:Class="Invoice.UI.Views.ExternalExpenseView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="💰 مصروفات خارجية"
        Height="600" Width="800"
        FontFamily="Cairo" FontSize="14"
        FlowDirection="RightToLeft"
        Background="#F9FAFB">

    <DockPanel Margin="20">

        <!-- العنوان -->
        <TextBlock DockPanel.Dock="Top"
                   Text="💰 إضافة مصروف خارجي"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#2563EB"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 15"/>

        <!-- نموذج الإدخال -->
        <Grid DockPanel.Dock="Top" Margin="0 0 0 15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- العمود 1 -->
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                <TextBlock Text="📅 التاريخ"/>
                <DatePicker SelectedDate="{Binding Date}"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                <TextBlock Text="📄 رقم الإفراج"/>
                <TextBox Text="{Binding ReleaseNumber}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                <TextBlock Text="💵 القيمة"/>
                <TextBox Text="{Binding Value}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                <TextBlock Text="⚖️ ضريبة القيمة المضافة"/>
                <TextBox Text="{Binding Vat}"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Margin="5">
                <TextBlock Text="🏢 ضريبة الأرباح التجارية"/>
                <TextBox Text="{Binding ProfitTax}"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="1" Margin="5">
                <TextBlock Text="🚢 ضريبة الوارد"/>
                <TextBox Text="{Binding ImportTax}"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="0" Margin="5">
                <TextBlock Text="💲 الرسوم"/>
                <TextBox Text="{Binding Fees}"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="1" Margin="5">
                <TextBlock Text="📊 الإجمالي"/>
                <TextBox Text="{Binding Total}"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Grid.Column="0" Margin="5">
                <TextBlock Text="🔢 رقم السداد الإلكتروني"/>
                <TextBox Text="{Binding EPaymentNumber}"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Grid.Column="1" Margin="5">
                <TextBlock Text="📝 البيان"/>
                <TextBox Text="{Binding Description}"/>
            </StackPanel>
        </Grid>

        <!-- زر الحفظ -->
        <DockPanel Margin="20">

            <TextBlock DockPanel.Dock="Top"
                   Text="💰 إضافة مصروف خارجي"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#2563EB"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 15"/>

            <!-- أزرار -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 20">
                <Button Content="➕ إضافة"
                    Background="#16A34A" Foreground="White"
                    FontWeight="Bold"
                    Width="120" Height="40"
                    Margin="10 0"
                    Click="AddExpense_Click"/>

                <Button Content="🗑 حذف المحدد"
                    Background="#DC2626" Foreground="White"
                    FontWeight="Bold"
                    Width="120" Height="40"
                    Margin="10 0"
                    Click="DeleteExpense_Click"/>
            </StackPanel>

            <!-- DataGrid -->
            <DataGrid ItemsSource="{Binding Expenses}"
                  SelectedItem="{Binding SelectedExpense}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="0"
                  HeadersVisibility="Column"
                  RowHeight="35">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="📅 التاريخ" Binding="{Binding Date, StringFormat=d}" Width="*" />
                    <DataGridTextColumn Header="📄 رقم الإفراج" Binding="{Binding ReleaseNumber}" Width="*" />
                    <DataGridTextColumn Header="💵 القيمة" Binding="{Binding Value}" Width="*" />
                    <DataGridTextColumn Header="⚖️ VAT" Binding="{Binding Vat}" Width="*" />
                    <DataGridTextColumn Header="🏢 أرباح تجارية" Binding="{Binding ProfitTax}" Width="*" />
                    <DataGridTextColumn Header="🚢 وارد" Binding="{Binding ImportTax}" Width="*" />
                    <DataGridTextColumn Header="💲 الرسوم" Binding="{Binding Fees}" Width="*" />
                    <DataGridTextColumn Header="📊 الإجمالي" Binding="{Binding Total}" Width="*" />
                    <DataGridTextColumn Header="🔢 السداد الإلكتروني" Binding="{Binding EPaymentNumber}" Width="*" />
                    <DataGridTextColumn Header="📝 البيان" Binding="{Binding Description}" Width="2*" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </DockPanel>
</Window>

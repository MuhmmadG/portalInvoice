<Window x:Class="Invoice.UI.Views.TaxReportView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 التقرير الضريبي"
        Height="550" Width="750"
        FontFamily="Cairo" FontSize="16"
        FlowDirection="RightToLeft"
        Background="#F9FAFB">

    <DockPanel Margin="20">

        <!-- ===== العنوان ===== -->
        <TextBlock DockPanel.Dock="Top"
                   Text="📊 التقرير الضريبي"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#2563EB"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 20"/>

        <!-- ===== اختيار الفترة ===== -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 20">
            <TextBlock Text="الشهر:" VerticalAlignment="Center" Margin="5"/>
            <ComboBox Width="80"
                      ItemsSource="{Binding Months}"
                      SelectedItem="{Binding SelectedMonth}" />

            <TextBlock Text="السنة:" VerticalAlignment="Center" Margin="10 0 5 0"/>
            <ComboBox Width="100"
                      ItemsSource="{Binding Years}"
                      SelectedItem="{Binding SelectedYear}" />

            <Button Content="تحميل التقرير"
                    Width="150" Margin="15 0"
                    Background="#2563EB"
                    Foreground="White"
                    FontWeight="Bold"
                    Padding="5"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="LoadReport_Click"/>
        </StackPanel>

        <!-- ===== النتائج ===== -->
        <Grid DockPanel.Dock="Top" Margin="0 0 0 20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- بطاقة المشتريات -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="15" Margin="10"
                    BorderBrush="#E5E7EB" BorderThickness="1" >
                <StackPanel>
                    <TextBlock Text="📥 المشتريات" FontSize="18" FontWeight="Bold" Foreground="#DC2626"/>
                    <Separator Margin="0 5"/>
                    <TextBlock Text="{Binding PurchasesTotal, StringFormat='الإجمالي: {0:N2}'}" Foreground="#374151"/>
                    <TextBlock Text="{Binding PurchasesT1, StringFormat='ضريبة T1: {0:N2}'}" Foreground="#6B7280"/>
                </StackPanel>
            </Border>

            <!-- بطاقة المبيعات -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="15" Margin="10"
                    BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="📤 المبيعات" FontSize="18" FontWeight="Bold" Foreground="#16A34A"/>
                    <Separator Margin="0 5"/>
                    <TextBlock Text="{Binding SalesTotal, StringFormat='الإجمالي: {0:N2}'}" Foreground="#374151"/>
                    <TextBlock Text="{Binding SalesT1, StringFormat='ضريبة T1: {0:N2}'}" Foreground="#6B7280"/>
                </StackPanel>
            </Border>

            <!-- بطاقة المصروفات الخارجية -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="15" Margin="10"
                    BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="🌍 مصروفات خارجية" FontSize="18" FontWeight="Bold" Foreground="#9333EA"/>
                    <Separator Margin="0 5"/>
                    <TextBlock Text="{Binding ExternalTotal, StringFormat='الإجمالي: {0:N2}'}" Foreground="#374151"/>
                    <TextBlock Text="{Binding ExternalVat, StringFormat='ضريبة VAT: {0:N2}'}" Foreground="#6B7280"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== المجموع النهائي ===== -->
        <Border Background="White" CornerRadius="12" Padding="15" Margin="10"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="📦 المجموع الكلي (داخلي + خارجي)" FontSize="18" FontWeight="Bold" Foreground="#2563EB"/>
                <Separator Margin="0 5"/>
                <TextBlock Text="{Binding CombinedTotal, StringFormat='إجمالي المشتريات: {0:N2}'}"
                           FontWeight="Bold" Foreground="#1D4ED8"/>
                <TextBlock Text="{Binding CombinedVat, StringFormat='إجمالي ضريبة VAT: {0:N2}'}"
                           FontWeight="Bold" Foreground="#059669"/>
            </StackPanel>
        </Border>

        <!-- ===== الفروق ===== -->
        <Border Background="White" CornerRadius="12" Padding="15" Margin="10"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="⚖️ الفروق" FontSize="18" FontWeight="Bold" Foreground="#F59E0B"/>
                <Separator Margin="0 5"/>
                <TextBlock Text="{Binding DifferenceSalesPurchases, StringFormat='فرق المبيعات - المشتريات: {0:N2}'}"
                           FontWeight="Bold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#16A34A"/>
                            <Style.Triggers>
                                <!-- لو النتيجة سالبة خليها حمراء -->
                                <DataTrigger Binding="{Binding DifferenceSalesPurchases}" Value="0">
                                    <Setter Property="Foreground" Value="#DC2626"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding DifferenceT1, StringFormat='فرق ضريبة T1: {0:N2}'}"
                           FontWeight="Bold"
                           Foreground="#EF4444"/>
            </StackPanel>
        </Border>

    </DockPanel>
</Window>

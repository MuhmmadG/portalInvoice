<Window x:Class="Invoice.UI.Views.CustomerJournalView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="📗 يومية العملاء"
        WindowStartupLocation="CenterScreen"
        Height="720" Width="1100"
        Background="#F9FAFB"
        FontFamily="Cairo"
        FontSize="14"
        FlowDirection="RightToLeft">

    <DockPanel Margin="10">

        <!-- 🔹 العنوان -->
        <TextBlock Text="📗 يومية العملاء"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#1E3A8A"
                   DockPanel.Dock="Top"
                   Margin="0,0,0,15"/>

        <!-- 🔹 فلاتر البحث -->
        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Top"
                    Margin="0,0,0,15"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">


            <TextBlock Text="من:" VerticalAlignment="Center"/>
            <DatePicker SelectedDate="{Binding StartDate}" Width="150" Margin="0,0,10,0"/>

            <TextBlock Text="إلى:" VerticalAlignment="Center"/>
            <DatePicker SelectedDate="{Binding EndDate}" Width="150" Margin="0,0,15,0"/>

            <TextBlock Text="👤 اختر العميل:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox ItemsSource="{Binding Customers}"
                      SelectedItem="{Binding SelectedCustomer}"
                      DisplayMemberPath="Name"
                      Width="200"
                      Height="32"
                      Margin="0,0,10,0"/>

            <Button Content="📊 تحميل اليومية"
                    Command="{Binding LoadJournalCommand}"
                    Background="#3B82F6"
                    Foreground="White"
                    FontWeight="Bold"
                    Width="150"
                    Margin="5,0"/>

            <Button Content="🧾 تصدير PDF"
                    Command="{Binding ExportPdfCommand}"
                    Background="#10B981"
                    Foreground="White"
                    FontWeight="Bold"
                    Width="150"
                    Margin="5,0"/>
        </StackPanel>

        <!-- 📋 جدول اليومية -->
        <DataGrid ItemsSource="{Binding JournalEntries}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  RowHeight="35"
                  AlternatingRowBackground="#E0E7FF"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column"
                  BorderBrush="#CBD5E1"
                  BorderThickness="1"
                  FontSize="13"
                  DockPanel.Dock="Top"
                  Height="480">

            <DataGrid.Columns>
                <!-- 📅 التاريخ -->
                <DataGridTextColumn Header="📅 التاريخ"
                        Binding="{Binding Date, StringFormat={}{0:yyyy/MM/dd}}"
                        Width="110"/>

                <!-- 🔢 رقم المستند -->
                <DataGridTextColumn Header="🔢 رقم المستند"
                        Binding="{Binding InvoiceNumber}"
                        Width="110"/>

                <!-- 💬 البيان / الوصف -->
                <DataGridTextColumn Header="💬 البيان / الوصف"
                        Binding="{Binding Description}"
                        Width="180"/>

                <!-- 💳 نوع التحصيل -->
                <DataGridTextColumn Header="💳 نوع التحصيل"
                        Binding="{Binding PaymentMethodDisplay}"
                        Width="130"/>

                <!-- 🏦 رقم الشيك / التحويل -->
                <DataGridTextColumn Header="🏦 رقم الشيك / التحويل"
                        Binding="{Binding ChequeNumber}"
                        Width="160"/>

                <!-- 🏛️ اسم البنك -->
                <DataGridTextColumn Header="🏛️ اسم البنك"
                        Binding="{Binding BankName}"
                        Width="130"/>
                <!-- 💵 القيم المالية -->
                <DataGridTextColumn Header="مدين (فاتورة)"
           Binding="{Binding DebitAmount, StringFormat=N2}"
           Width="120"/>
                <!-- 💸 تفاصيل الضريبة -->
                <DataGridTemplateColumn Header="معدل الضريبة %" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding TaxDetailsList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Rate, StringFormat={}{0:N2}%}"
                                       HorizontalAlignment="Center"
                                       Foreground="#1E3A8A"
                                       FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="قيمة الضريبة" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding TaxDetailsList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Amount, StringFormat={}{0:N2}}"
                                       HorizontalAlignment="Center"
                                       Foreground="#111827"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

             

                <DataGridTextColumn Header="دائن (تحصيل)"
                        Binding="{Binding CreditAmount, StringFormat=N2}"
                        Width="120"/>

                <DataGridTextColumn Header="💰 الرصيد"
                        Binding="{Binding Balance, StringFormat=N2}"
                        Width="130"/>
            </DataGrid.Columns>

        </DataGrid>

        <!-- 🧮 قسم الإجماليات -->
        <Border DockPanel.Dock="Bottom"
                Margin="0,10,0,0"
                Padding="10"
                Background="#EEF2FF"
                BorderBrush="#C7D2FE"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- إجمالي قيمة الفاتورة -->
                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="إجمالي قيمة الفاتورة"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,3"
                               HorizontalAlignment="Center"/>
                    <TextBox Text="{Binding TotalInvoiceValue, Mode=OneWay, StringFormat=N2}"
                             HorizontalContentAlignment="Center"
                             FontSize="14"
                             FontWeight="Bold"
                             Foreground="#111827"
                             IsReadOnly="True"
                             Background="WhiteSmoke"/>
                </StackPanel>

                <!-- إجمالي 1% -->
                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="إجمالي 1%" 
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,3"
                               HorizontalAlignment="Center"/>
                    <TextBox Text="{Binding TotalTax1, Mode=OneWay, StringFormat=N2}"
                             HorizontalContentAlignment="Center"
                             FontSize="14"
                             FontWeight="Bold"
                             Foreground="#111827"
                             IsReadOnly="True"
                             Background="WhiteSmoke"/>
                </StackPanel>

                <!-- إجمالي 14% -->
                <StackPanel Grid.Column="2" Margin="5">
                    <TextBlock Text="إجمالي 14%"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,3"
                               HorizontalAlignment="Center"/>
                    <TextBox Text="{Binding TotalTax14, Mode=OneWay, StringFormat=N2}"
                             HorizontalContentAlignment="Center"
                             FontSize="14"
                             FontWeight="Bold"
                             Foreground="#111827"
                             IsReadOnly="True"
                             Background="WhiteSmoke"/>
                </StackPanel>

                <!-- إجمالي المبيعات -->
                <StackPanel Grid.Column="3" Margin="5">
                    <TextBlock Text="إجمالي المبيعات"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,3"
                               HorizontalAlignment="Center"/>
                    <TextBox Text="{Binding TotalSales, Mode=OneWay, StringFormat=N2}"
                             HorizontalContentAlignment="Center"
                             FontSize="14"
                             FontWeight="Bold"
                             Foreground="DarkGreen"
                             IsReadOnly="True"
                             Background="WhiteSmoke"/>
                </StackPanel>
                <!-- إجمالي التحصيلات -->
                <StackPanel Grid.Column="4" Margin="5">
                    <TextBlock Text="إجمالي التحصيلات"
               FontWeight="Bold"
               Foreground="#1E3A8A"
               Margin="0,0,0,3"
               HorizontalAlignment="Center"/>
                    <TextBox Text="{Binding TotalReceipts, Mode=OneWay, StringFormat=N2}"
             HorizontalContentAlignment="Center"
             FontSize="14"
             FontWeight="Bold"
             Foreground="DarkRed"
             IsReadOnly="True"
             Background="WhiteSmoke"/>
                </StackPanel>
                <!-- ✅ إجمالي المرتجعات -->
                <StackPanel Grid.Column="5" Margin="5">
                    <TextBlock Text="إجمالي المرتجعات"
               FontWeight="Bold"
               Foreground="#B91C1C"
               Margin="0,0,0,3"
               HorizontalAlignment="Center"/>
                    <TextBox Text="{Binding TotalReturns, Mode=OneWay, StringFormat=N2}"
             HorizontalContentAlignment="Center"
             FontSize="14"
             FontWeight="Bold"
             Foreground="#B91C1C"
             IsReadOnly="True"
             Background="WhiteSmoke"/>
                </StackPanel>
                <StackPanel Grid.Column="6" Margin="5">
                    <TextBlock Text="الرصيد النهائي"
               FontWeight="Bold"
               Foreground="#065F46"
               Margin="0,0,0,3"
               HorizontalAlignment="Center"/>
                    <TextBox Text="{Binding FinalBalance, Mode=OneWay, StringFormat=N2}"
             HorizontalContentAlignment="Center"
             FontSize="14"
             FontWeight="Bold"
             Foreground="#065F46"
             IsReadOnly="True"
             Background="WhiteSmoke"/>
                </StackPanel>
            </Grid>
        </Border>

    </DockPanel>
</Window>

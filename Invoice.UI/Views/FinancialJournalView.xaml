<Window x:Class="Invoice.UI.Views.FinancialJournalView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="📘 اليومية المالية"
        Height="750" Width="1200"
        Background="#F9FAFB"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen">

    <DockPanel Margin="20">

        <!-- 🔹 العنوان -->
        <TextBlock Text="📘 اليومية المالية"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#1E3A8A"
                   DockPanel.Dock="Top"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 15"/>

        <!-- 🔸 الفلاتر -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 0 15">
            <TextBlock Text="من:" VerticalAlignment="Center" Margin="5 0"/>
            <DatePicker SelectedDate="{Binding StartDate}" Width="150"/>

            <TextBlock Text="إلى:" VerticalAlignment="Center" Margin="10 0 0 0"/>
            <DatePicker SelectedDate="{Binding EndDate}" Width="150"/>

            <!-- 🟢 نوع المصروف -->
            <TextBlock Text="💼 نوع المصروف:" VerticalAlignment="Center" Margin="15 0 5 0"/>
            <ComboBox ItemsSource="{Binding ExpenseCategories}"
              DisplayMemberPath="CategoryType"
              SelectedItem="{Binding SelectedExpenseCategory, Mode=TwoWay}"
              Width="220" Height="32"/>

            <Button Content="📊 تحميل اليومية"
            Command="{Binding LoadCommand}"
            Background="#2563EB" Foreground="White"
            FontWeight="Bold" Width="160" Margin="15 0"/>
            <Button Content="🖨️ طباعة PDF"
        Command="{Binding PrintCommand}"
        Background="#16A34A" Foreground="White"
        FontWeight="Bold" Width="140" Margin="10 0"/>

        </StackPanel>


        <!-- 📋 الجدول -->
        <Border Background="White"
                CornerRadius="10"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="10">
            <DataGrid ItemsSource="{Binding JournalEntries}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="40"
                      AlternatingRowBackground="#F3F4F6"
                      FontSize="14">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="📅 التاريخ"
                                        Binding="{Binding TransactionDate, StringFormat={}{0:yyyy/MM/dd}}"
                                        Width="130"/>
                    <DataGridTextColumn Header="الوصف"
                                        Binding="{Binding Description}"
                                        Width="300"/>
                    <DataGridTextColumn Header="مدين"
                                        Binding="{Binding Debit, StringFormat={}{0:N2}}"
                                        Width="120"/>
                    <DataGridTextColumn Header="دائن"
                                        Binding="{Binding Credit, StringFormat={}{0:N2}}"
                                        Width="120"/>
                    <DataGridTextColumn Header="عمولة البنك"
                                        Binding="{Binding BankCommission, StringFormat={}{0:N2}}"
                                        Width="130"/>
                    <DataGridTextColumn Header="الرصيد"
                                        Binding="{Binding Balance, StringFormat={}{0:N2}}"
                                        Width="130"
                                        FontWeight="Bold"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 🧮 الإجماليات -->
        <Border DockPanel.Dock="Bottom"
                Margin="0 15 0 0"
                Background="#EEF2FF"
                Padding="10"
                CornerRadius="8"
                BorderBrush="#C7D2FE"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- إجمالي المدين -->
                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="إجمالي المصروفات (مدين)"
                               FontWeight="Bold"
                               Foreground="#B91C1C"
                               Margin="0,0,0,5"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalDebit, StringFormat={}{0:N2}}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#B91C1C"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- إجمالي الدائن -->
                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="إجمالي السداد (دائن)"
                               FontWeight="Bold"
                               Foreground="DarkGreen"
                               Margin="0,0,0,5"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalCredit, StringFormat={}{0:N2}}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="DarkGreen"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- الرصيد النهائي -->
                <StackPanel Grid.Column="2" Margin="5">
                    <TextBlock Text="الرصيد النهائي"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,5"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Balance, StringFormat={}{0:N2}}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </DockPanel>
</Window>

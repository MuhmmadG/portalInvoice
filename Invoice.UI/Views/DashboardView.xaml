<Window x:Class="Invoice.UI.Views.DashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F6FA"
        Title="نظام الفواتير - الرئيسية" Icon="C:\InvoicePortal\Invoice.UI\Resorces\report.ico">
    <Window.Resources>
        <Style x:Key="SideButton" TargetType="Button">
            <Setter Property="Background" Value="#4B5563"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="10"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6B7280"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="260"/>

            <!-- Content Area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--======================  Sidebar Navigation  ======================-->
        <Border Background="#1F2937" Grid.Column="0">
            <StackPanel>

                <!-- Logo -->
                <TextBlock Text="Invoice System"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="22"
                           Margin="20"/>

                <!-- SALES MODULE -->
                <Expander Header="🧾 المبيعات" Foreground="White"
                          Background="#374151" Margin="5" FontSize="18">
                    <StackPanel Margin="10">
                        <Button Content="فاتورة بيع" Style="{StaticResource SideButton}" Click="Sales_Click"/>
                        <Button Content="تقرير العملاء" Style="{StaticResource SideButton}" Click="ShowCustomerReport"/>
                        <Button Content="يومية العملاء" Style="{StaticResource SideButton}" Click="OpenCustomerJournal"/>
                        <Button Content="فواتير العملاء" Style="{StaticResource SideButton}" Click="CustomerInvoices"/>
                        <Button Content="رصيد العملاء" Style="{StaticResource SideButton}" Click="CustomerBalances"/>
                        <Button Content="📊 اتجهات الاسعار" Click="PriceTrends" Style="{StaticResource SideButton}"/>
 



                    </StackPanel>
                </Expander>

                <!-- PURCHASE MODULE -->
                <Expander Header="🛒 المشتريات" Foreground="White"
                          Background="#374151" Margin="5" FontSize="18">
                    <StackPanel Margin="10">
                        <Button Content="فاتورة شراء" Style="{StaticResource SideButton}" Click="Purchase_Click"/>
                        <Button Content="يومية الموردين" Style="{StaticResource SideButton}" Click="SupplierJournal"/>
                        <Button Content="فواتير الموردين" Style="{StaticResource SideButton}" Click="SupplierInvoices"/>
                        <Button Content="رصيد الموردين" Style="{StaticResource SideButton}" Click="SupplierBalancesView"/>
                        <Button Content="تقرير المشتريات الخارجية" Style="{StaticResource SideButton}" Click="ExternalPurchaseReport"/>
                    </StackPanel>
                </Expander>

                <!-- EXPENSE MODULE -->
                <Expander Header="💰 المصروفات" Foreground="White"
                          Background="#374151" Margin="5" FontSize="18">
                    <StackPanel Margin="10">
                        <Button Content="مصاريف خارجية" Style="{StaticResource SideButton}" Click="ShowExternalExpense"/>
                        <Button Content="مصروفات أخرى" Style="{StaticResource SideButton}" Click="OtherExpense"/>
                        <Button Content="تحليل المصروفات" Style="{StaticResource SideButton}" Click="OpenExpenseAnalysis"/>
                    </StackPanel>
                </Expander>

                <!-- REPORTS MODULE -->
                <Expander Header="📊 التقارير" Foreground="White"
                          Background="#374151" Margin="5" FontSize="18">
                    <StackPanel Margin="10">
                        <Button Content="تقرير الأصناف" Style="{StaticResource SideButton}" Click="ShowProductReport"/>
                        <Button Content="تقرير القيمة المضافة" Style="{StaticResource SideButton}" Click="ShowTaxReport_Click"/>
                        <Button Content="تقرير المصروفات الأخرى" Style="{StaticResource SideButton}" Click="ReportOthetExpanses"/>
                    </StackPanel>
                    
                </Expander>
                <Expander Header="📊 المعاملات" Foreground="White"
                           Background="#374151" Margin="5" FontSize="18">
                    <Button Content="🔁 المعاملات" Click="Transaction" Style="{StaticResource SideButton}"/>
                     
                </Expander>

            </StackPanel>
        </Border>

        <!--======================  Content Area  ======================-->
        <Grid Grid.Column="1" Background="White">
            <TextBlock Text="مرحبًا بك في نظام الفواتير"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="32"
                       Foreground="#333"/>
        </Grid>

    </Grid>

</Window>

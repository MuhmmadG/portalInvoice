<Window x:Class="Invoice.UI.Views.CustomerReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Invoice.UI.ViewModels"
        Title="تقرير العملاء" Height="600" Width="1000"
        Background="#f5f6fa" WindowStartupLocation="CenterScreen">
  


    <DockPanel Margin="10">
        <!-- منطقة الفلترة -->
        <Border DockPanel.Dock="Top" 
                Background="#2c3e50" 
                CornerRadius="8" 
                Padding="10" 
                Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="السنة:" Foreground="White" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox Width="120" 
                          ItemsSource="{Binding Years}" 
                          SelectedItem="{Binding SelectedYear}" 
                          Margin="0,0,20,0"/>

                <TextBlock Text="الشهر:" Foreground="White" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox Width="120" 
                          ItemsSource="{Binding Months}" 
                          SelectedItem="{Binding SelectedMonth}"/>
            </StackPanel>
        </Border>

        <!-- الجدول -->
        <Border CornerRadius="8" BorderBrush="#bdc3c7" BorderThickness="1" Background="White" Padding="5">
            <DataGrid ItemsSource="{Binding Reports}" AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#ecf0f1"
                      RowBackground="White"
                      GridLinesVisibility="None"
                      Margin="0"
                      BorderThickness="0"
                      FontSize="14"
                      FontFamily="Segoe UI"
                      RowHeight="35">

                <DataGrid.Resources>
                    <!-- ستايل لتوسيط النصوص -->
                    <Style TargetType="DataGridCell">
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="5,0"/>
                    </Style>
                    <!-- ستايل لعناوين الأعمدة -->
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Background" Value="#34495e"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="5"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="الإجمالي الكلي" Binding="{Binding GrandTotal}" Width="120"/>
                    <DataGridTextColumn Header="إجمالي الضرائب" Binding="{Binding TotalTax}" Width="120"/>
                    <DataGridTextColumn Header="إجمالي المبيعات" Binding="{Binding TotalSales}" Width="120"/>
                    <DataGridTextColumn Header="إجمالي الكمية" Binding="{Binding TotalQuantity}" Width="120"/>
                    <DataGridTextColumn Header="السنة" Binding="{Binding Year}" Width="80"/>
                    <DataGridTextColumn Header="الشهر" Binding="{Binding Month}" Width="80"/>
                    <DataGridTextColumn Header="السعر" Binding="{Binding Price}" Width="100"/>
                    <DataGridTextColumn Header="الكود الداخلي" Binding="{Binding InternalCode}" Width="150"/>
                    <DataGridTextColumn Header="النوع" Binding="{Binding Kind}" Width="100"/>
                    <DataGridTextColumn Header="العميل" Binding="{Binding CustomerName}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</Window>

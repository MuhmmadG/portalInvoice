<Window x:Class="Invoice.UI.Views.CustomerBalancesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="أرصدة العملاء"
        Height="500"
        Width="900"
        FlowDirection="RightToLeft"
        Background="#F5F6FA">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- عنوان الشاشة -->
        <Border Background="#2C3E50"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,10">

            <TextBlock Text="📊 تقرير أرصدة العملاء"
                       FontSize="20"
                       Foreground="White"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>


        <!-- جدول البيانات -->

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Balances}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  RowHeight="35"
                  FontSize="14"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  AlternatingRowBackground="#F1F2F6"
                  RowBackground="White"
                  BorderThickness="0"
                  SelectionMode="Single">

            <!-- تنسيق رأس الأعمدة -->
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="15"/>
                    <Setter Property="Background" Value="#34495E"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <!-- تمييز صف الإجمالي -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">

                    <Style.Triggers>

                        <DataTrigger Binding="{Binding CustomerName}"
                                     Value="--- الإجمالي العام ---">

                            <Setter Property="Background" Value="#FFF3CD"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="15"/>

                        </DataTrigger>

                    </Style.Triggers>

                </Style>
            </DataGrid.RowStyle>


            <DataGrid.Columns>

                <DataGridTextColumn Header="اسم العميل"
                                    Binding="{Binding CustomerName}"
                                    Width="2*"/>

                <DataGridTextColumn Header="إجمالي مدين"
                                    Binding="{Binding TotalDebit,StringFormat=N2}"
                                    Width="*"/>

                <DataGridTextColumn Header="إجمالي دائن"
                                    Binding="{Binding TotalCredit,StringFormat=N2}"
                                    Width="*"/>

                <DataGridTextColumn Header="الرصيد"
                                    Binding="{Binding NetBalance,StringFormat=N2}"
                                    Width="*"/>

                <DataGridTextColumn Header="الحالة"
                                    Binding="{Binding BalanceStatus}"
                                    Width="*"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>

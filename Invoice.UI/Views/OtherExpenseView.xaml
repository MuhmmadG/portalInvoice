<Window x:Class="Invoice.UI.Views.OtherExpenseView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="📋 المصروفات الأخرى"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F9FAFB"
        FlowDirection="RightToLeft">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Inputs -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- 🟦 العنوان -->
        <Border Background="#2563EB" CornerRadius="8" Padding="10" Margin="0 0 0 15" >
            <TextBlock Text="📑 إدارة المصروفات الأخرى"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- 🧾 إدخال البيانات -->
        <Border Grid.Row="1" Padding="10" CornerRadius="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0 0 0 15">
            <UniformGrid Columns="6" Rows="2" Margin="0" VerticalAlignment="Center" HorizontalAlignment="Center" >
                <StackPanel Margin="5">
                    <TextBlock Text="📅 التاريخ" FontWeight="Bold"/>
                    <DatePicker SelectedDate="{Binding Date}" />
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="🧾 البيان" FontWeight="Bold"/>
                    <TextBox Text="{Binding Description}" Height="28" />
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="📂 التصنيف" FontWeight="Bold"/>
                    <ComboBox ItemsSource="{Binding ExpenseCategories}"
                              DisplayMemberPath="CategoryType"
                              SelectedItem="{Binding SelectedCategory}"
                              Height="28"/>
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="💰 القيمة" FontWeight="Bold"/>
                    <TextBox Text="{Binding Value}" Height="28"/>
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="🏦 العمولة البنكية" FontWeight="Bold"/>
                    <TextBox Text="{Binding BankCommission}" Height="28"/>
                </StackPanel>

                <StackPanel Margin="5" VerticalAlignment="Bottom">
                    <TextBlock Text="الإجمالي" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Total, StringFormat={}{0:F2}}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#2563EB"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <!-- 📋 الجدول -->
        <Border Grid.Row="2" CornerRadius="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Expenses}"
                      SelectedItem="{Binding SelectedExpense , Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      RowHeight="35"
                      FontSize="14"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F3F4F6"
                      BorderThickness="0"
                      Margin="5">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="📅 التاريخ" Binding="{Binding Date, StringFormat=d}" Width="120"/>
                    <DataGridTextColumn Header="البيان" Binding="{Binding Description}" Width="200"/>
                    <DataGridTextColumn Header="التصنيف" Binding="{Binding ExpenseCategory.CategoryType}" Width="150"/>
                    <DataGridTextColumn Header="القيمة" Binding="{Binding Value}" Width="100" />
                    <DataGridTextColumn Header="العمولة البنكية" Binding="{Binding BankCommission}" Width="150"/>
                    <DataGridTextColumn Header="الإجمالي" Binding="{Binding Total}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 🔘 الأزرار -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0 15 0 0">

            <Border CornerRadius="8" Background="#22C55E" Margin="5">
                <Button Content="➕ إضافة"
            Command="{Binding AddCommand}"
            Background="Transparent"
            Foreground="White"
            FontWeight="Bold"
            BorderThickness="0"
            Cursor="Hand"
            Width="130"
            Height="38"/>
            </Border>


            <Button Content="💾 حفظ"
                    Command="{Binding SaveCommand}"
                   Background="Transparent"
Foreground="Blue"
FontWeight="Bold"
BorderThickness="0"
Cursor="Hand"
Width="130"
Height="38"/>

            <Button Content="🗑 حذف"
                    Command="{Binding DeleteCommand}"
                    Width="130"
                    Height="38"
                    Background="#DC2626"
                    Foreground="White"
                    FontWeight="Bold"
                    Cursor="Hand"
                    BorderThickness="0"
                  />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="Invoice.UI.Views.SupplierJournalView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="📒 دفتر اليومية للمورد"
        Height="750" Width="1250"
        Background="#F9FAFB"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen">
    <!-- 🧮 قسم الإجماليات -->
        <Border DockPanel.Dock="Bottom"
                Margin="0,10,0,0"
                Padding="10"
                Background="#EEF2FF"
                BorderBrush="#C7D2FE"
                BorderThickness="1"
                CornerRadius="8">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- العنوان -->
                <RowDefinition Height="Auto"/>
                <!-- شريط الأدوات -->
                <RowDefinition Height="*"/>
                <!-- الجدول -->
                <RowDefinition Height="Auto"/>
                <!-- الإجماليات -->
            </Grid.RowDefinitions>

            <!-- 🟦 العنوان -->
            <TextBlock Grid.Row="0"
               Text="📒 دفتر اليومية - الموردين"
               FontSize="22"
               FontWeight="Bold"
               Foreground="#1E3A8A"
               Margin="0,0,0,15"
               HorizontalAlignment="Center"/>

            <!-- 🔽 شريط التحكم -->
            <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                Margin="0,0,0,10"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">
                <TextBlock Text="من:" VerticalAlignment="Center" Margin="5,0"/>
                <DatePicker SelectedDate="{Binding StartDate}" Width="150" Margin="0,0,10,0"/>

                <TextBlock Text="إلى:" VerticalAlignment="Center" Margin="5,0"/>
                <DatePicker SelectedDate="{Binding EndDate}" Width="150" Margin="0,0,10,0"/>

                <TextBlock Text="🏢 اختر المورد:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <ComboBox ItemsSource="{Binding Suppliers}"
                  SelectedItem="{Binding SelectedSupplier}"
                  DisplayMemberPath="Name"
                  Width="200"
                  Height="32"
                  Margin="0,0,10,0"/>

                <Button Content="📊 تحميل اليومية"
                Command="{Binding LoadJournalCommand}"
                Background="#3B82F6"
                Foreground="White"
                FontWeight="Bold"
                Width="150"
                Margin="5,0"/>

                <Button Content="🧾 تصدير PDF"
                Command="{Binding ExportPdfCommand}"
                Background="#10B981"
                Foreground="White"
                FontWeight="Bold"
                Width="150"
                Margin="5,0"/>
            </StackPanel>

            <!-- 📊 جدول اليومية -->
            <Border Grid.Row="2"
            Background="White"
            CornerRadius="10"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
                    <DataGrid ItemsSource="{Binding JournalEntries}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="40"
                      AlternatingRowBackground="#F3F4F6"
                      FontSize="14"
                      CanUserSortColumns="True"
                      ScrollViewer.CanContentScroll="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="📅 التاريخ"
                                        Binding="{Binding Date, StringFormat={}{0:yyyy/MM/dd}}"
                                        Width="120"/>
                            <DataGridTextColumn Header="📄 رقم الفاتورة" Binding="{Binding InvoiceNumber}" Width="140"/>
                            <DataGridTextColumn Header="📘 الوصف" Binding="{Binding Description}" Width="200"/>
                            

                            <DataGridTemplateColumn Header="معدل الضريبة %" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding TaxDetailsList}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Rate, StringFormat={}{0:N2}%}"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#1E3A8A"
                                                       FontWeight="SemiBold"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="قيمة الضريبة" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding TaxDetailsList}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Amount, StringFormat={}{0:N2}}"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#111827"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="مدين" Binding="{Binding DebitAmount, StringFormat={}{0:N2}}" Width="120"/>
                            <DataGridTextColumn Header="دائن" Binding="{Binding Credit, StringFormat={}{0:N2}}" Width="120"/>
                            <DataGridTextColumn Header="🧾 الرصيد"
                                        Binding="{Binding Balance, StringFormat={}{0:N2}}"
                                        Width="130"
                                        FontWeight="Bold"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </ScrollViewer>
            </Border>

            <!-- 🧮 قسم الإجماليات -->
            <Border Grid.Row="3"
            Margin="0,10,0,0"
            Padding="10"
            Background="#EEF2FF"
            BorderBrush="#C7D2FE"
            BorderThickness="1"
            CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- إجمالي المشتريات -->
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="إجمالي المشتريات"
                           FontWeight="Bold"
                           Foreground="#1E3A8A"
                           Margin="0,0,0,3"
                           HorizontalAlignment="Center"/>
                        <TextBox Text="{Binding TotalPurchases, Mode=OneWay, StringFormat=N2}"
                         HorizontalContentAlignment="Center"
                         FontSize="14"
                         FontWeight="Bold"
                         Foreground="#111827"
                         IsReadOnly="True"
                         Background="WhiteSmoke"/>
                    </StackPanel>

                    <!-- إجمالي 1% -->
                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="إجمالي 1%" 
                           FontWeight="Bold"
                           Foreground="#1E3A8A"
                           Margin="0,0,0,3"
                           HorizontalAlignment="Center"/>
                        <TextBox Text="{Binding TotalTax1, Mode=OneWay, StringFormat=N2}"
                         HorizontalContentAlignment="Center"
                         FontSize="14"
                         FontWeight="Bold"
                         Foreground="#111827"
                         IsReadOnly="True"
                         Background="WhiteSmoke"/>
                    </StackPanel>

                    <!-- إجمالي 14% -->
                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="إجمالي 14%"
                           FontWeight="Bold"
                           Foreground="#1E3A8A"
                           Margin="0,0,0,3"
                           HorizontalAlignment="Center"/>
                        <TextBox Text="{Binding TotalTax14, Mode=OneWay, StringFormat=N2}"
                         HorizontalContentAlignment="Center"
                         FontSize="14"
                         FontWeight="Bold"
                         Foreground="#111827"
                         IsReadOnly="True"
                         Background="WhiteSmoke"/>
                    </StackPanel>

                    <!-- إجمالي المشتريات شامل الضريبة -->
                    <StackPanel Grid.Column="3" Margin="5">
                        <TextBlock Text="إجمالي المشتريات (شامل الضريبة)"
                           FontWeight="Bold"
                           Foreground="#1E3A8A"
                           Margin="0,0,0,3"
                           HorizontalAlignment="Center"/>
                        <TextBox Text="{Binding TotalInvoiceValue, Mode=OneWay, StringFormat=N2}"
                         HorizontalContentAlignment="Center"
                         FontSize="14"
                         FontWeight="Bold"
                         Foreground="DarkGreen"
                         IsReadOnly="True"
                         Background="WhiteSmoke"/>
                    </StackPanel>

                    <!-- إجمالي المدفوعات -->
                    <StackPanel Grid.Column="4" Margin="5">
                        <TextBlock Text="إجمالي المدفوعات"
                           FontWeight="Bold"
                           Foreground="#B91C1C"
                           Margin="0,0,0,3"
                           HorizontalAlignment="Center"/>
                        <TextBox Text="{Binding TotalPayments, Mode=OneWay, StringFormat=N2}"
                         HorizontalContentAlignment="Center"
                         FontSize="14"
                         FontWeight="Bold"
                         Foreground="#B91C1C"
                         IsReadOnly="True"
                         Background="WhiteSmoke"/>
                    </StackPanel>
                    <!-- ✅ إجمالي المرتجعات -->
                    <StackPanel Grid.Column="5" Margin="5">
                        <TextBlock Text="إجمالي المرتجعات"
               FontWeight="Bold"
               Foreground="#B91C1C"
               Margin="0,0,0,3"
               HorizontalAlignment="Center"/>
                        <TextBox Text="{Binding TotalReturns, Mode=OneWay, StringFormat=N2}"
             HorizontalContentAlignment="Center"
             FontSize="14"
             FontWeight="Bold"
             Foreground="#B91C1C"
             IsReadOnly="True"
             Background="WhiteSmoke"/>
                    </StackPanel>

                    <!-- ✅ الرصيد النهائي -->
                    <StackPanel Grid.Column="6" Margin="5">
                        <TextBlock Text="الرصيد النهائي"
               FontWeight="Bold"
               Foreground="#065F46"
               Margin="0,0,0,3"
               HorizontalAlignment="Center"/>
                        <TextBox Text="{Binding FinalBalance, Mode=OneWay, StringFormat=N2}"
             HorizontalContentAlignment="Center"
             FontSize="14"
             FontWeight="Bold"
             Foreground="#065F46"
             IsReadOnly="True"
             Background="WhiteSmoke"/>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </Border>
   
</Window>

<Window x:Class="Invoice.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📑 نظام الفواتير"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#F9FAFB"
        Height="600" Width="950">

    <Window.Resources>

        <!-- ستايل TextBox -->
        <Style x:Key="FlatTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#2563EB"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#F3F4F6"/>
                    <Setter Property="Foreground" Value="#374151"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ستايل Button -->
        <Style TargetType="Button" x:Key="FlatButton">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E3A8A"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#9CA3AF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <DockPanel Margin="15">

        <!-- أزرار -->
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0 0 0 15">
            <Button Command="{Binding SaveInvoiceCommand}" Content="💾 ترحيل إلى الإكسل" Style="{StaticResource FlatButton}"/>
            <Button Command="{Binding SelectFolderCommand}" Content="📂 اختر المجلد" Style="{StaticResource FlatButton}"/>
            <Button Command="{Binding ShowInvoicesCommand}" Content="👁 عرض البيانات" Style="{StaticResource FlatButton}"/>
            <Button Command="{Binding SaveDataBaseCommand}" Content="حفظ" Style="{StaticResource FlatButton}"/>
          
            
        </StackPanel>

        <!-- ملخص الفواتير -->
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0 0 0 15" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="عدد الفواتير" FontWeight="Bold"/>
                <TextBox Text="{Binding InvoiceCount}" IsReadOnly="True" Width="150" Margin="5" Style="{StaticResource FlatTextBox}"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="المبيعات" FontWeight="Bold"/>
                <TextBox Text="{Binding SalesTotal}" IsReadOnly="True" Width="150" Margin="5" Style="{StaticResource FlatTextBox}"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="ضريبة القيمة المضافة" FontWeight="Bold"/>
                <TextBox Text="{Binding VatTotal}" IsReadOnly="True" Width="150" Margin="5" Style="{StaticResource FlatTextBox}"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="ضريبة 1%" FontWeight="Bold"/>
                <TextBox Text="{Binding Tax1Total}" IsReadOnly="True" Width="150" Margin="5" Style="{StaticResource FlatTextBox}"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="إجمالي المبيعات" FontWeight="Bold"/>
                <TextBox Text="{Binding GrandTotal}" IsReadOnly="True" Width="150" Margin="5" Style="{StaticResource FlatTextBox}"/>
            </StackPanel>
        </StackPanel>

        <!-- جدول الفواتير -->
        <DataGrid ItemsSource="{Binding Invoices}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  FlowDirection="RightToLeft"
                  Margin="10"
                  FontSize="14"
                  RowDetailsVisibilityMode="Visible"
                  AlternatingRowBackground="WhiteSmoke"
                  RowBackground="White"
                  GridLinesVisibility="None">

            <!-- ستايل الهيدر -->
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#3B82F6"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Padding" Value="8,4"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <!-- ستايل الصفوف -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Margin" Value="2"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="ToolTip" Value="انقر لعرض التفاصيل"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E0F2FE"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <!-- الأعمدة الرئيسية -->
            <DataGrid.Columns>
                <DataGridTextColumn Header="📅 التاريخ" Binding="{Binding DateTimeReceived}" Width="150"/>
                <DataGridTextColumn Header="👤 اسم العميل" Binding="{Binding Receiver.Name}" Width="200"/>
                <DataGridTextColumn Header="🔢 رقم الفاتورة" Binding="{Binding InternalId}" Width="120"/>
                <DataGridTextColumn Header="💰 الإجمالي" Binding="{Binding TotalAmount}" Width="120"/>
            </DataGrid.Columns>

            <!-- تفاصيل الفاتورة -->
            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border BorderBrush="#3B82F6" BorderThickness="1" CornerRadius="8" Padding="12" Margin="5">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="📝 تفاصيل الفاتورة" 
                                       FontWeight="Bold" 
                                       FontSize="15" 
                                       Foreground="#1E3A8A"
                                       Margin="0,0,0,8"/>

                            <DataGrid ItemsSource="{Binding InvoiceLines}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      FlowDirection="RightToLeft"
                                      FontSize="13"
                                      HeadersVisibility="Column"
                                      AlternatingRowBackground="LightGray"
                                      RowBackground="White"
                                      GridLinesVisibility="None"
                                      BorderThickness="0"
                                      Margin="0,5,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="📌 الوصف" Binding="{Binding Description}" Width="200"/>
                                    <DataGridTextColumn Header="📦 الكمية" Binding="{Binding Quantity}" Width="100"/>
                                    <DataGridTextColumn Header="💵 المبلغ" Binding="{Binding SalesTotal}" Width="120"/>
                                    <DataGridTemplateColumn Header="⚖️ الضرائب" Width="180">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding TaxableItems}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#3B82F6" BorderThickness="1" CornerRadius="5" Padding="4" Margin="3">
                                                                <StackPanel Orientation="Horizontal" >
                                                                    <TextBlock Text="{Binding TaxType}" FontWeight="Bold" Foreground="#1E3A8A"/>
                                                                    <TextBlock Text=": "/>
                                                                    <TextBlock Text="{Binding Amount}" Foreground="DarkGreen"/>
                                                                    <TextBlock Text=" [" Foreground="Gray"/>
                                                                    <TextBlock Text="Rate:" Foreground="Gray"/>
                                                                    <TextBlock Text="{Binding Rate}" Foreground="DarkRed"/>
                                                                    <TextBlock Text="%]" Foreground="Gray"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="🔖 الإجمالي" Binding="{Binding Total}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>

    </DockPanel>
</Window>
